# Smart City Dashboard — Environment Variables Example
# Copy this file to .env and add your API key

# Option 1: OpenRouter API Key (recommended, free tier available)
# Get yours at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_key_here

# Option 2: Hugging Face Token
# Get yours at: https://huggingface.co/settings/tokens
VITE_HF_TOKEN=your_hf_token_here
